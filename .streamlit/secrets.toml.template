# Secrets Configuration Template for Streamlit Cloud
# Copy this to secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

# Required: OpenAI API Key for LLM operations
OPENAI_API_KEY = "your-openai-api-key-here"

# Optional: Additional API keys for enhanced features
# Uncomment and add keys if you want to enable these features:

# SEMANTIC_SCHOLAR_API_KEY = "your-semantic-scholar-key"
# NEWS_API_KEY = "your-news-api-key"

# System Configuration
[research_config]
max_agents = 3
timeout_seconds = 30
memory_limit_items = 50

# Cost Control Settings
[cost_control]
max_tokens_per_request = 200
max_requests_per_session = 20
alert_threshold_dollars = 1.00

# Deployment Settings
[deployment]
environment = "production"
debug_mode = false
enable_metrics = true